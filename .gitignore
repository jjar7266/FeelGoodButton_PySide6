# ============================================================
# Python
# ============================================================
__pycache__/
*.pyc
*.pyo
*.pyd
*.cache

# ============================================================
# Virtual Environments
# ============================================================
.venv/
venv/
env/

# uv environment + lock file
.uv/
uv.lock

# ============================================================
# Build / Distribution Artifacts (PyInstaller)
# ============================================================
build/
dist/
*.spec

# PyInstaller output
*.exe
*.dll
*.manifest
*.pkg
*.so

# PyInstaller temp files
*.tmp
*.bak
*.old

# ============================================================
# Nuitka (optional future packaging)
# ============================================================
.nuitka/
*.build
*.dist
*.onefile-build
*.onefile-dist

# Nuitka cache
__nuitka_cache__/

# ============================================================
# OS Junk
# ============================================================
.DS_Store
Thumbs.db

# ============================================================
# Editor / IDE
# ============================================================
.vscode/
.idea/
*.swp
*.swo

# ============================================================
# Logs
# ============================================================
*.log

# ============================================================
# Audio Files (optional)
# If you want to track audio, remove this section.
# ============================================================
audio/*.wav
audio/*.mp3
audio/*.ogg

# ============================================================
# Qt / PySide6 Specific
# ============================================================
# Qt Designer autosaves
*.autosave

# Qt cache
*.qcache
*.qmlc
*.jsc

# Qt plugin directories (PyInstaller will bundle these)
qt_plugins/
PySide6/plugins/

# ============================================================
# Local Config Files
# ============================================================
.env
*.local
